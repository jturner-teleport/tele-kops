# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit real values.

# ── Prefix ─────────────────────────────────────────────────────────────────────
export PREFIX="yourname"                         # unique prefix for all resource names (e.g. jturner)

# ── AWS ────────────────────────────────────────────────────────────────────────
export AWS_PROFILE="teleport-dev-admin"          # SSO profile name from ~/.aws/config (not "default")
export AWS_PAGER=""                              # disable AWS CLI pager (prevents interactive less prompts)
export AWS_REGION="us-east-1"
export AWS_AZ="${AWS_REGION}a"                   # first AZ in region; override if needed (e.g. eu-west-1a)
export AWS_ACCOUNT_ID=""                         # auto-detected if blank

# ── kops ───────────────────────────────────────────────────────────────────────
export CLUSTER_NAME="dev.k8s.local"              # must end in .k8s.local (gossip DNS)
export K8S_API_DOMAIN="k8s.teleport.yourdomain.com"  # custom DNS for kubectl (CNAME → API ELB)
export KOPS_STATE_BUCKET="${PREFIX}-tele-kops-state"
export KOPS_STATE_STORE="s3://${KOPS_STATE_BUCKET}"
export KOPS_SSH_PUBLIC_KEY="${HOME}/.ssh/id_rsa.pub"

# ── Worker nodes ───────────────────────────────────────────────────────────────
export WORKER_MIN="1"
export WORKER_MAX="2"

# ── Teleport ───────────────────────────────────────────────────────────────────
export TELEPORT_VERSION="18"                     # major version; pin to avoid surprise upgrades
export TELEPORT_DOMAIN="teleport.yourdomain.com"
export TELEPORT_BACKEND_TABLE="${PREFIX}-tele-backend"
export TELEPORT_EVENTS_TABLE="${PREFIX}-tele-events"
export TELEPORT_SESSIONS_BUCKET="${PREFIX}-tele-sessions"

# ── Route53 ────────────────────────────────────────────────────────────────────
export ROUTE53_HOSTED_ZONE_ID="ZXXXXXXXXXXXXX"   # hosted zone ID for your domain

# ── cert-manager ───────────────────────────────────────────────────────────────
export LETSENCRYPT_EMAIL="you@example.com"
